<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" spacing="12.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ini.eprojectuas.controller.TambahPemakaianViewController">
   <children>
      <Label text="Catat Pemakaian Barang">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <VBox.margin>
            <Insets bottom="8.0" />
         </VBox.margin>
      </Label>
      
      <VBox spacing="4.0">
         <children>
            <Label text="NIM Pemakai" />
            <TextField fx:id="fieldNim" promptText="Masukkan NIM mahasiswa" />
         </children>
      </VBox>
      
      <VBox spacing="4.0">
         <children>
            <Label text="Barang (Consumable)" />
            <ComboBox fx:id="comboBarang" prefWidth="400.0" promptText="Pilih barang yang digunakan" />
         </children>
      </VBox>
      
      <VBox spacing="4.0">
         <children>
            <Label text="Jumlah" />
            <TextField fx:id="fieldJumlah" promptText="Masukkan jumlah pemakaian" />
         </children>
      </VBox>
      
      <VBox spacing="4.0">
         <children>
            <Label text="Tujuan Pemakaian" />
            <TextArea fx:id="areaTujuan" prefHeight="60.0" promptText="Contoh: Praktikum Jaringan Komputer, Tugas Akhir, dll." wrapText="true" />
         </children>
      </VBox>
      
      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button fx:id="btnBatal" mnemonicParsing="false" prefHeight="32.0" prefWidth="80.0" text="Batal" />
            <Button fx:id="btnSimpan" mnemonicParsing="false" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #1e64d4; -fx-text-fill: white; -fx-font-weight: bold;" text="Simpan" />
         </children>
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
   </padding>
</VBox>